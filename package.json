{
  "name": "edi-document-assistant",
  "private": true,
  "workspaces": ["apps/*"],
  "devDependencies": {
    "prisma": "^6.5.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "vite": "^6.0.0",
    "jsdom": "^25.0.0"
  },
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "api": "cd apps/api && bun run start:dev",
    "api:test": "cd apps/api && bun run test",
    "api:lint": "cd apps/api && bun run lint",
    "web": "cd apps/web && bun run dev",
    "web:test": "cd apps/web && bun run test",
    "web:lint": "cd apps/web && bun run lint",
    "web:build": "cd apps/web && bun run build",
    "dc:up": "docker compose up -d postgres minio",
    "dc:down": "docker compose down",
    "dc:ps": "docker compose ps",
    "dc:clean": "docker compose down -v",
    "dc:logs": "docker compose logs -f",
    "dc:logs:pg": "docker compose logs -f postgres",
    "dc:logs:minio": "docker compose logs -f minio",
    "dc:all": "docker compose up -d",
    "db:generate": "bunx prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "bunx prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "bunx prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed": "cd apps/api && bun run seed",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:studio": "bunx prisma studio --schema=apps/api/prisma/schema.prisma"
  }
}
